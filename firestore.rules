rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // RÈGLES DE SÉCURITÉ — Sarkin Wanka Fashion Design
    // ============================================================

    // Tâches (commandes) : lecture/écriture publique pour l'instant
    // TODO: restreindre à des utilisateurs authentifiés quand Firebase Auth sera actif
    match /tasks/{taskId} {
      allow read, write: if true;
      // À remplacer par :
      // allow read, write: if request.auth != null;
    }

    // Paramètres : lecture/écriture publique (document unique 'main')
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // Tailleurs : lecture pour vérification login, écriture publique
    match /tailors/{tailorId} {
      allow read: if true;
      allow write: if true;
      // TODO: restreindre l'écriture aux admins authentifiés
    }

    // Ping de connectivité Firebase (indicateur de statut en temps réel)
    match /_ping/{docId} {
      allow read, write: if true;
    }

    // Bloquer tout le reste
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
